# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local import/seed outputs (never commit)
import-credentials.txt
import-results.json
data/import-dry-run.json
data/consolidate-report.json
data/missing-catalog-import.json

# scraped data (never commit)
data/serpapi-*.json
!data/seed/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Cursor IDE session state (debug logs, etc.)
.cursor/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
