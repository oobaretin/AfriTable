# Copy these lines into `.env.local` (not committed). SerpAPI dashboard: https://serpapi.com/manage-api-key
#
# Free plan is often ~250 searches/month. Each metro run uses:
#   - 13 Google Maps "search" calls (cuisine queries)
#   - plus up to N "place" calls (1 per venue detail — the expensive part)
#
# Recommended for 250/mo:
SERPAPI_KEY=
SERPAPI_FREE_TIER=1
SERPAPI_MAX_PLACE_DETAILS=5
#
# Thinnest data, lowest cost (~13 searches per metro, no place lookups):
# SERPAPI_SKIP_PLACE_DETAILS=1
