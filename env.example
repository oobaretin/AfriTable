## Supabase
# Public (safe to expose to the browser)
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://sunbwzzmnaudvmpohpyj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

## Email (SMTP — no Resend; e.g. Gmail + App Password for sending)
# The site shows @afritable.com addresses publicly. Server-side notifications go to SITE_INBOX_EMAIL (set to your real inbox, e.g. personal Gmail — never exposed in the UI).
# 1) Google Account → Security → App passwords (if using Gmail SMTP).
# 2) Set:
GMAIL_USER=
GMAIL_APP_PASSWORD=
# From header for outbound mail. With Gmail SMTP, usually the same as GMAIL_USER. For a branded From at your domain, use a provider that supports it.
EMAIL_FROM=
# Where API/form notifications are delivered (server-only). Example: your personal Gmail. If unset, defaults to contact@afritable.com (ensure DNS/forwarding or override here).
SITE_INBOX_EMAIL=
#
# Alternative: generic SMTP instead of GMAIL_* — set SMTP_HOST, SMTP_USER, SMTP_PASS (optional SMTP_PORT, SMTP_SECURE=true for 465).
# Or a single connection string: SMTP_URL=smtps://user:pass@smtp.example.com:465
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Cron
CRON_SECRET=

## SerpAPI (for restaurant scraping)
# Get free API key from: https://serpapi.com/users/sign_up
SERPAPI_KEY=

