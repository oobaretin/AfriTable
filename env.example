## Supabase
# Public (safe to expose to the browser)
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://sunbwzzmnaudvmpohpyj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false

# Server-only (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

## Email (SMTP — no paid API; e.g. Gmail + App Password)
# Easiest: same Google account for sending and receiving.
# 1) Google Account → Security → 2-Step Verification → App passwords → generate for "Mail".
# 2) Set:
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional: From header (defaults to GMAIL_USER). Use the same address you authenticated with.
EMAIL_FROM=
# Receives copies of public form notifications. Defaults to therealtasteofafrica@gmail.com if unset.
SITE_INBOX_EMAIL=
#
# Alternative: generic SMTP instead of GMAIL_* — set SMTP_HOST, SMTP_USER, SMTP_PASS (optional SMTP_PORT, SMTP_SECURE=true for 465).
# Or a single connection string: SMTP_URL=smtps://user:pass@smtp.example.com:465
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Cron
CRON_SECRET=

## SerpAPI (for restaurant scraping)
# Get free API key from: https://serpapi.com/users/sign_up
SERPAPI_KEY=

